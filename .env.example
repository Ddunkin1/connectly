APP_NAME=Laravel
APP_ENV=local
# Unique Compose project name (avoids Docker ghost-container attach errors)
COMPOSE_PROJECT_NAME=connectlyapp
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# For Laravel Herd (use connectly-app.test after migration):
# APP_URL=http://connectly-app.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: all app data (users, posts, etc.) — use Navicat to connect to this MySQL.
# - Sail's MySQL container: DB_HOST=mysql (and uncomment mysql service in compose.yaml).
# - Your MySQL on host (Navicat = single source): DB_HOST=host.docker.internal (and keep mysql commented in compose.yaml).
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=connectly_app
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# For Laravel Herd (frontend API calls):
# VITE_API_URL=http://connectly-app.test

# Production (Vercel frontend + separate Laravel API):
# FRONTEND_URL=https://connectlyproject.vercel.app
# CORS_ALLOWED_ORIGINS=https://connectlyproject.vercel.app
# Optional when redirect differs from APP_URL + /api/auth/google/callback:
# GOOGLE_REDIRECT_URI=https://your-api-domain.com/api/auth/google/callback

# Supabase — media storage only (pictures, videos). Not used as database; all app data is in MySQL.
# Used for: profile/cover images, post media, message attachments, stories
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=publicConnectly
# Set true if profile/cover images 502 locally (PHP in Docker cannot reach Supabase; browser loads direct URL)
# SUPABASE_IMAGE_REDIRECT_ONLY=false

# Cover image proxy base URL (when request host is wrong behind proxy, e.g. Vite + Sail)
# Local Sail: COVER_PROXY_BASE=http://localhost
# Local artisan serve: COVER_PROXY_BASE=http://localhost:8000
# Production: leave unset to use APP_URL
# COVER_PROXY_BASE=http://localhost
